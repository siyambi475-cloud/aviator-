<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121214">

    <!-- ১. বড় বা মেইন নিচের ওয়েব ভিউ (ফুল স্ক্রিন) -->
    <android.webkit.WebView
        android:id="@+id/main_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ২. উপরের বাম কর্নারের ছোট স্কয়ার ওয়েব ভিউ -->
    <!-- লাল বর্ডার দেওয়ার জন্য আমরা এটিকে একটি View-এর মধ্যে রাখছি -->
    <RelativeLayout
        android:layout_width="250dp"
        android:layout_height="150dp"
        android:layout_margin="20dp"
        android:background="@android:color/transparent">
        
        <!-- আপনার কাঙ্ক্ষিত লাল বর্ডারসহ কন্টেইনার -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/red_border" />

        <android.webkit.WebView
            android:id="@+id/top_webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2dp" />
    </RelativeLayout>

</RelativeLayout>
