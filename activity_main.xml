<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121214">

    <!-- নিচের মেইন বা বড় ওয়েব ভিউ -->
    <android.webkit.WebView
        android:id="@+id/main_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- উপরের বাম কর্নারের ছোট কন্টেইনার (লাল বর্ডারসহ) -->
    <RelativeLayout
        android:layout_width="250dp"
        android:layout_height="150dp"
        android:layout_margin="20dp">
        
        <!-- লাল বর্ডার দেওয়ার জন্য ব্যাকগ্রাউন্ড ভিউ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:borderWidth="2dp"
            android:borderColor="#e21b3c" />

        <android.webkit.WebView
            android:id="@+id/top_webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2dp" />
    </RelativeLayout>

</RelativeLayout>
